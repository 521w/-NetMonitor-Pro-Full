<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D1B2A">
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbarSettings"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="#1B2838" android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" xmlns:app="http://schemas.android.com/apk/res-auto"/>
    <FrameLayout android:id="@+id/settingsContainer"
        android:layout_width="match_parent" android:layout_height="match_parent"/>
</LinearLayout>
