<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5">
  <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NetMonitor Pro" android:textSize="26sp" android:textStyle="bold" android:textColor="#1976D2" android:layout_marginBottom="2dp"/>
    <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Monitoring Active" android:textSize="13sp" android:textColor="#4CAF50" android:layout_marginBottom="16dp"/>
    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Risk Level" android:textSize="13sp" android:textColor="#757575"/>
        <TextView android:id="@+id/tvRiskScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="48sp" android:textStyle="bold" android:textColor="#4CAF50"/>
        <TextView android:id="@+id/tvRiskLabel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOW" android:textSize="15sp" android:textColor="#4CAF50"/>
        <ProgressBar android:id="@+id/progressRisk" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_marginTop="8dp" android:max="100" android:progress="0"/>
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
      <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginEnd="6dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Connections" android:textSize="12sp" android:textColor="#757575"/>
          <TextView android:id="@+id/tvConnections" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="24sp" android:textStyle="bold" android:textColor="#1976D2"/>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>
      <com.google.android.material.card.MaterialCardView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="6dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
          <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data" android:textSize="12sp" android:textColor="#757575"/>
          <TextView android:id="@+id/tvDataTransferred" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 KB" android:textSize="24sp" android:textStyle="bold" android:textColor="#1976D2"/>
        </LinearLayout>
      </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
    <com.google.android.material.card.MaterialCardView android:id="@+id/cardAlerts" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone" app:cardCornerRadius="12dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFF3E0">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alerts" android:textSize="15sp" android:textStyle="bold" android:textColor="#E65100"/>
        <TextView android:id="@+id/tvAlerts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textSize="13sp" android:textColor="#BF360C"/>
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="4dp">
      <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Network Flow" android:textSize="13sp" android:textColor="#757575" android:layout_marginBottom="8dp"/>
        <com.netmonitor.pro.ui.FlowGraphView android:id="@+id/flowGraph" android:layout_width="match_parent" android:layout_height="180dp"/>
      </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recent Events" android:textSize="17sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="8dp"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvEvents" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
  </LinearLayout>
</ScrollView>
